{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@workspace/source"],
    "baseUrl": ".",
    "paths": {
      "@workspace/drizzle-pg": ["libs/drizzle-pg/src/index.ts"],
      "@workspace/errors": ["libs/errors/src/index.ts"],
      "@workspace/kafka": ["libs/kafka/src/index.ts"],
      "@workspace/logger": ["libs/logger/src/index.ts"],
      "@workspace/payment": ["libs/payment/src/index.ts"],
      "@workspace/utils": ["libs/utils/src/index.ts"],
      "drizzle-orm": ["node_modules/drizzle-orm"],
      "drizzle-orm/*": ["node_modules/drizzle-orm/*"]
    }
  }
}
